    "description": "Test call state can be cleaned up by autoclear",
    "steps" : [
      {"t":"jsonfile", "name": "messagesoverlay.json", "json": {"autoclear": 600}, "text": "Force autoclear setting on"},
      {"t":"cmd", "js": "Bangle.setLocked(true)", "text": "Lock the bangle to force autoclear to become active"},
      {"t":"cmd", "js": "var testfunc = ()=>{}; Bangle.on('swipe', testfunc)", "text": "This is the canary for detecting if the call prevented proper restoration by the later text message"},
      {"t":"cmd", "js": "require('messagesoverlay').message('call', {src:'Caller',t:'add',id:'call',title:'title',body:'body'})", "text": "Show call"},
      {"t":"advanceTimers", "ms":700000, "text": "Advance timers to get the timer to fire in the next idle period"},
      {"t":"cmd", "js": "require('messagesoverlay').message('text', {src:'Messenger',t:'add',type:'text',id:Date.now().toFixed(0),title:'testmessage',body:'body'})", "text": "Show a message overlay after call"},
      {"t":"emit", "event": "touch", "paramsArray": [ 1, { "x": 10, "y": 10, "type": 0 } ], "text": "Close message"},
      {"t":"assert", "js": "Bangle['#onswipe'][0]===testfunc", "is":"true", "text": "The swipe handler has been restored"}
    ]
  },{
    "description": "Test buzzing state switches correctly on overlay close",
    "steps" : [
      {"t":"jsonfile", "name": "messagesoverlay.json", "json": {"autoclear": 600}, "text": "Force autoclear setting on"},
      {"t":"cmd", "js": "Bangle.setLocked(true)", "text": "Lock the bangle to force autoclear to become active"},
      {"t":"jsonfile", "name": "setting.json", "json": {"quiet": 0}, "text": "Disable quiet mode"},
      {"t":"wrap", "fn": "Bangle.buzz", "id": "buzz", "name": "Count attempts to buzz"},
      {"t":"cmd", "js": "require('messagesoverlay').message('text', {src:'Messenger',t:'add',type:'text',id:Date.now().toFixed(0),title:'testmessage',body:'body'})", "text": "Show a message overlay"},
      {"t":"assertCall", "id": "buzz", "count": 1, "text": "First message buzzes, enabled cooldown timeout"},
      {"t":"emit", "event": "touch", "paramsArray": [ 1, { "x": 10, "y": 10, "type": 0 } ], "text": "Close message to disable cooldown"},
      {"t":"cmd", "js": "require('messagesoverlay').message('text', {src:'Messenger',t:'add',type:'text',id:Date.now().toFixed(0),title:'testmessage',body:'body'})", "text": "Show a message overlay"},
      {"t":"assertCall", "id": "buzz", "count": 2, "text": "This message buzzes as well"}
    ]
  },{
    "description": "Test removeAllListeners during overlay does not remove all listeners",
    "steps" : [
      {"t":"cmd", "js": "Bangle.on('canary', ()=>{})", "text": "This is the canary for detecting if other events stayed untouched"},
      {"t":"assert", "js": "Bangle['#oncanary'].length", "is": "equal", "to": 1, "text": "Expect one canary listener"},
      {"t":"cmd", "js": "require('messagesoverlay').message('text', {src:'Messenger',t:'add',type:'text',id:Date.now().toFixed(0),title:'testmessage',body:'body'})", "text": "Show a message overlay"},
      {"t":"cmd", "js": "Bangle.removeAllListeners('swipe')", "text": "Remove unrelated listeners"},
      {"t":"assert", "js": "Bangle['#oncanary'].length", "is": "equal", "to": 1, "text": "Expect one listener, they are not backgrounded"},
      {"t":"emit", "event": "touch", "paramsArray": [ 1, { "x": 10, "y": 10, "type": 0 } ], "text": "Close message to restore message listener"},
      {"t":"assert", "js": "Bangle['#oncanary'].length", "is": "equal", "to": 1, "text": "Expect one listener, removing one category of listeners should leave others untouched"}
    ]
  },{
    "description": "Test setWatch/clearWatch during overlay works",
    "steps" : [
      {"t":"cmd", "js": "setWatch(()=>{}, BTN)", "text": "Set a watch"},
      {"t":"cmd", "js": "setWatch(()=>{}, BTN)", "text": "Set a second watch"},
      {"t":"assert", "js": "global[\"\\xff\"].watches.filter(w=>w).length", "is": "equal", "to": 2, "text": "Expect our watches"},
      {"t":"cmd", "js": "require('messagesoverlay').message('text', {src:'Messenger',t:'add',type:'text',id:Date.now().toFixed(0),title:'testmessage',body:'body'})", "text": "Show a message overlay"},
      {"t":"cmd", "js": "var overlayWatch = setWatch(()=>{}, BTN); clearWatch(overlayWatch);", "text": "Set and clear a watch during overlay"},
      {"t":"cmd", "js": "Bangle.removeAllListeners('swipe')", "text": "Remove unrelated listeners"},
      {"t":"emit", "event": "touch", "paramsArray": [ 1, { "x": 10, "y": 10, "type": 0 } ], "text": "Close message to restore message listener"},
      {"t":"assert", "js": "global[\"\\xff\"].watches.filter(w=>w).length", "is": "equal", "to": 2, "text": "Expect our watches and nothing else"}
    ]
  }]
